<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Mi Aventura Escolar</title>

<style>

body{
    margin:0;
    padding:20px;
    background:linear-gradient(#87CEEB,#BDEFFF);
    font-family:'Comic Sans MS',sans-serif;
    text-align:center;
}

h1{
    color:#ff6b6b;
    margin-bottom:10px;
}

#stats{
    background:white;
    max-width:350px;
    margin:auto;
    padding:15px;
    border-radius:20px;
    box-shadow:0 4px 10px rgba(0,0,0,.15);
}

#map{
    display:flex;
    flex-direction:column;
    align-items:center;
    margin-top:30px;
}

.level{
    width:130px;
    height:130px;
    border-radius:50%;
    display:flex;
    flex-direction:column;
    justify-content:center;
    align-items:center;
    margin:10px;
    cursor:pointer;
    transition:.3s;
    font-size:42px;
    font-weight:bold;
}

.level span{
    font-size:14px;
    margin-top:8px;
}

.unlocked{
    background:#4ecdc4;
    color:white;
}

.locked{
    background:#d9d9d9;
    color:#777;
    opacity:.6;
    cursor:not-allowed;
}

.completed{
    background:gold;
    color:#333;
}

.path{
    width:10px;
    height:50px;
    background:white;
    border-radius:10px;
}

.current{
    animation:pulse 1.5s infinite;
}

@keyframes pulse{

0%{
transform:scale(1);
}

50%{
transform:scale(1.12);
}

100%{
transform:scale(1);
}

}

button{
    margin-top:20px;
    padding:12px 20px;
    border:none;
    border-radius:12px;
    background:#ff6b6b;
    color:white;
    font-size:16px;
    cursor:pointer;
}

#message{
    margin-top:20px;
    font-size:20px;
    font-weight:bold;
}

</style>

</head>
<body>

<h1>🌟 Mi Aventura Escolar 🌟</h1>

<div id="stats">

<h2>⭐ Puntos: <span id="points">0</span></h2>

<h3>🏆 Mundo actual:
<span id="currentWorld">
Bosque de las Letras
</span>
</h3>

</div>

<div id="map"></div>

<div id="message"></div>

<button onclick="completeCurrentWorld()">
Completar Mundo
</button>

<script>

const worlds = [

{
id:1,
name:"Bosque de las Letras",
emoji:"🔤"
},

{
id:2,
name:"Valle de las Palabras",
emoji:"📖"
},

{
id:3,
name:"Montaña de los Números",
emoji:"🔢"
},

{
id:4,
name:"Cueva de las Sumas",
emoji:"➕"
},

{
id:5,
name:"Isla de las Figuras",
emoji:"🔺"
},

{
id:6,
name:"Selva de los Animales",
emoji:"🌱"
},

{
id:7,
name:"Planeta Verde",
emoji:"♻️"
},

{
id:8,
name:"Reino de los Colores",
emoji:"🎨"
},

{
id:9,
name:"Ciudad Musical",
emoji:"🎵"
},

{
id:10,
name:"Castillo del Primer Grado",
emoji:"👑"
}

];

let completedWorlds =
JSON.parse(
localStorage.getItem("completedWorlds")
) || [];

let points =
parseInt(
localStorage.getItem("points")
) || 0;

function renderMap(){

const map =
document.getElementById("map");

map.innerHTML="";

worlds.forEach((world,index)=>{

const div =
document.createElement("div");

let unlocked =
index===0 ||
completedWorlds.includes(index);

let completed =
completedWorlds.includes(world.id);

div.classList.add("level");

if(completed){

div.classList.add("completed");

}
else if(unlocked){

div.classList.add("unlocked");

}
else{

div.classList.add("locked");

}

if(
!completed &&
unlocked
){

div.classList.add("current");

}

div.innerHTML=
`
${world.emoji}
<span>${world.name}</span>
`;

map.appendChild(div);

if(index < worlds.length-1){

const path =
document.createElement("div");

path.className="path";

map.appendChild(path);

}

});

updateStats();

}

function updateStats(){

document
.getElementById("points")
.textContent =
points;

let current =
worlds.find(
w =>
!completedWorlds.includes(w.id)
);

if(current){

document
.getElementById("currentWorld")
.textContent =
current.name;

}
else{

document
.getElementById("currentWorld")
.textContent =
"¡Graduado! 🎓";

}

}

function completeCurrentWorld(){

let current =
worlds.find(
w =>
!completedWorlds.includes(w.id)
);

if(!current){

document
.getElementById("message")
.innerHTML =
"🎉 ¡Completaste toda la aventura!";

return;

}

completedWorlds.push(current.id);

points += 100;

localStorage.setItem(
"completedWorlds",
JSON.stringify(completedWorlds)
);

localStorage.setItem(
"points",
points
);

document
.getElementById("message")
.innerHTML =
`🏆 Has completado ${current.name}`;

renderMap();

}

renderMap();

</script>

</body>
</html>
